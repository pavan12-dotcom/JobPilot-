# ─────────────────────────────────────────────────────────────
# ApplyAI Backend — Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────────

# App
NODE_ENV=development
PORT=3000

# ─── Database ─────────────────────────────────────────────────
# PostgreSQL connection string
# Local Docker: postgresql://applyai:applyai_secret@localhost:5432/applyai_db
# Railway: provided automatically
DATABASE_URL=postgresql://applyai:applyai_secret@localhost:5432/applyai_db

# ─── Redis ────────────────────────────────────────────────────
# Redis connection URL for Bull queues
# Local Docker: redis://localhost:6379
REDIS_URL=redis://localhost:6379

# ─── Supabase ─────────────────────────────────────────────────
# Get from: https://supabase.com/dashboard → Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here
SUPABASE_STORAGE_BUCKET=resumes

# ─── Claude AI ────────────────────────────────────────────────
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# ─── Gemini AI ────────────────────────────────────────────────
# Get from: https://aistudio.google.com/
GEMINI_API_KEY=AIzaSy...

# ─── Job APIs ─────────────────────────────────────────────────
# Adzuna: https://developer.adzuna.com/ (free tier: 250 req/month)
ADZUNA_APP_ID=your-adzuna-app-id
ADZUNA_APP_KEY=your-adzuna-app-key
ADZUNA_COUNTRY=in

# Remotive: No API key needed (public API)
REMOTIVE_API_URL=https://remotive.com/api/remote-jobs

# The Muse: https://www.themuse.com/developers/api/v2 (free)
THEMUSE_API_KEY=your-themuse-api-key

# ─── Free Job Platforms (no API key needed) ───────────────────
# LinkedIn: Uses the public guest job search API (no auth required)
# Indeed:   Uses the public RSS feed (no auth required)
# Naukri:   Uses the internal JSON search API (no auth required)
# All three are enabled automatically when the server starts.
# No extra configuration needed.

# ─── Email (Nodemailer) ───────────────────────────────────────
# Using Gmail: enable "App Passwords" in Google Account
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=ApplyAI <noreply@applyai.dev>

# ─── JWT ─────────────────────────────────────────────────────
# Used for demo/local auth (replace with Supabase in production)
JWT_SECRET=change-this-to-a-random-64-char-string

# ─── Frontend ─────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3001

# ─── Bull Board (queue monitor UI) ────────────────────────────
BULL_BOARD_USERNAME=admin
BULL_BOARD_PASSWORD=admin123
